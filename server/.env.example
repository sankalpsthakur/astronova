# Backend configuration
FLASK_DEBUG=true
PORT=8080
DB_PATH=./astronova.db
ASTRONOVA_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# AI Chat (at least one required for Oracle chat)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Authentication
JWT_SECRET=              # REQUIRED in production. The server refuses to start
                         # signing tokens with the dev fallback when FLASK_ENV/
                         # APP_ENV/ENV=production. JWT_SECRET_KEY is also accepted
                         # for existing Render blueprints.
APPLE_BUNDLE_ID=         # Required for Apple Sign-In and App Store receipt checks
ADMIN_API_TOKEN=         # Required for /api/v1/admin endpoints

# Analytics privacy
IP_HASH_SALT=            # REQUIRED in production (>= 8 chars). Salts the IP hash
                         # in request analytics; without it every request 500s
                         # when FLASK_ENV/ENV=production.

# Payments / App Store verification (required to grant entitlements from real
# purchases). Without a trusted root, /api/v1/payments/verify fails closed.
APPLE_ROOT_CA_PEM=       # PEM contents of "Apple Root CA - G3" (inline)
APPLE_ROOT_CA_PATH=      # ...or a path to the PEM file (alternative to _PEM)
# Register the App Store Server Notifications V2 URL in App Store Connect:
#   POST {host}/api/v1/payments/notifications

# Rate limiting. Defaults to in-process memory, which does NOT share limits
# across Gunicorn workers — set a shared store in production.
RATELIMIT_STORAGE_URI=   # e.g. redis://host:6379 (REDIS_URL is also accepted)
ASTRONOVA_DISABLE_RATE_LIMITS=  # set to 1 only for local/dev to disable limits


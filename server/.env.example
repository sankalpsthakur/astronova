# Backend configuration
FLASK_DEBUG=true
PORT=8080
DB_PATH=./astronova.db
ASTRONOVA_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# AI Chat (at least one required for Oracle chat)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Authentication
JWT_SECRET=              # REQUIRED in production. The server refuses to start
                         # signing tokens with the dev fallback when FLASK_ENV/
                         # APP_ENV/ENV=production. JWT_SECRET_KEY is also accepted
                         # for existing Render blueprints.
APPLE_BUNDLE_ID=         # Required for Apple Sign-In and App Store receipt checks
ADMIN_API_TOKEN=         # Required for /api/v1/admin endpoints
IP_HASH_SALT=            # Required in production for stable, non-reversible IP hash logs

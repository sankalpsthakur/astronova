# Backend configuration
FLASK_DEBUG=true
PORT=8080
DB_PATH=./astronova.db

# AI Chat (at least one required for Oracle chat)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Authentication
JWT_SECRET=              # Set in production; JWT_SECRET_KEY is accepted for existing Render blueprints
APPLE_BUNDLE_ID=         # Required for Apple Sign-In
ADMIN_API_TOKEN=         # Required for /api/v1/admin endpoints

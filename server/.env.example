# Backend configuration
FLASK_DEBUG=true
PORT=8080
DB_PATH=./astronova.db

# AI Chat (at least one required for Oracle chat)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Authentication
JWT_SECRET=              # Auto-generated if not set; set in production
APPLE_BUNDLE_ID=         # Required for Apple Sign-In
